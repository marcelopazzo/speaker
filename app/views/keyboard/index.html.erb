<div class="keyboard-container" data-controller="keyboard">
  <div class="text-input-container">
    <textarea
      id="text-input"
      class="text-input"
      rows="3"
      readonly
      data-keyboard-target="input"
    ></textarea>
    <button class="clear-button" data-keyboard-target="clearButton" data-action="click->keyboard#clearText">×</button>
    <div class="suggestion-container">
      <div data-keyboard-target="suggestion" class="suggestion"></div>
      <button class="copy-suggestion-button" data-keyboard-target="copySuggestion" data-action="click->keyboard#copySuggestion">⬆</button>
    </div>
  </div>

  <div class="keyboard" id="abc-keyboard">
    <div class="keyboard-row">
      <% "abcdefghij".each_char do |key| %>
        <button class="key" data-key="<%= key %>"><%= key %></button>
      <% end %>
      <button class="key key-wide" data-key="backspace">⌫</button>
    </div>

    <div class="keyboard-row">
      <% "klmnopqrst".each_char do |key| %>
        <button class="key" data-key="<%= key %>"><%= key %></button>
      <% end %>
      <button class="key key-wide" data-keyboard-target="speakButton" data-action="click->keyboard#speakText" data-key="">🔊</button>
    </div>

    <div class="keyboard-row">
      <% "uvwxyzç,.".each_char do |key| %>
        <button class="key" data-key="<%= key %>"><%= key %></button>
      <% end %>
      <button class="key" data-key=" ">␣</button>
      <button id="keyboard-toggle-abc" class="key key-wide" data-keyboard-target="toggleButton" data-action="click->keyboard#toggleLayout" data-key="">123</button>
    </div>
  </div>

  <div class="keyboard hidden" id="number-keyboard">
    <div class="keyboard-row">
      <% "123@#$%&*".each_char do |key| %>
        <button class="key" data-key="<%= key %>"><%= key %></button>
      <% end %>
      <button class="key key-wide" data-key="backspace">⌫</button>
    </div>

    <div class="keyboard-row">
      <% "4560+-=()".each_char do |key| %>
        <button class="key" data-key="<%= key %>"><%= key %></button>
      <% end %>
      <button class="key key-wide" data-keyboard-target="speakButton" data-action="click->keyboard#speakText" data-key="">🔊</button>
    </div>

    <div class="keyboard-row">
      <% "789/,.!?".each_char do |key| %>
        <button class="key" data-key="<%= key %>"><%= key %></button>
      <% end %>
      <button class="key" data-key=" ">␣</button>
      <button id="keyboard-toggle-num" class="key key-wide" data-keyboard-target="toggleButton" data-action="click->keyboard#toggleLayout" data-key="">QWE</button>
    </div>
  </div>

  <div class="keyboard hidden" id="qwerty-keyboard">
    <div class="keyboard-row">
      <% "QWERTYUIOP".each_char do |key| %>
        <button class="key" data-key="<%= key %>"><%= key %></button>
      <% end %>
      <button class="key key-wide" data-key="backspace">⌫</button>
    </div>

    <div class="keyboard-row">
      <% "ASDFGHJKLÇ".each_char do |key| %>
        <button class="key" data-key="<%= key %>"><%= key %></button>
      <% end %>
      <button class="key key-wide" data-keyboard-target="speakButton" data-action="click->keyboard#speakText" data-key="">🔊</button>
    </div>

    <div class="keyboard-row">
      <% "ZXCVBNM".each_char do |key| %>
        <button class="key" data-key="<%= key %>"><%= key %></button>
      <% end %>
      <button class="key" data-key=",">,</button>
      <button class="key" data-key=".">.</button>
      <button class="key" data-key=" ">␣</button>
      <button id="keyboard-toggle" class="key key-wide" data-keyboard-target="toggleButton" data-action="click->keyboard#toggleLayout" data-key="">ABC</button>
    </div>
  </div>
</div>
